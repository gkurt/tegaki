{
  "name": "tegaki-generator",
  "version": "0.19.0",
  "private": true,
  "type": "module",
  "description": "Generate handwriting animation data from any font — extracts skeletons, computes stroke order, outputs animated SVGs",
  "keywords": [
    "handwriting",
    "font",
    "skeleton",
    "stroke-order",
    "svg",
    "animation",
    "cli",
    "google-fonts",
    "skeletonization",
    "zhang-suen"
  ],
  "homepage": "https://github.com/gkurt/tegaki#readme",
  "bugs": {
    "url": "https://github.com/gkurt/tegaki/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gkurt/tegaki.git",
    "directory": "packages/generator"
  },
  "license": "MIT",
  "author": {
    "name": "Gokhan Kurt",
    "email": "krtgkn@gmail.com",
    "url": "https://gkurt.com"
  },
  "bin": {
    "tegaki": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "start": "bun --conditions=tegaki@dev src/cli/index.ts",
    "compile": "bun build --compile --minify --outfile dist src/cli/index.ts",
    "test": "bun --conditions=tegaki@dev test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "d3-delaunay": "^6.0.4",
    "harfbuzzjs": "^1.4.0",
    "fflate": "^0.8.3",
    "opentype.js": "^2.0.0",
    "padrone": "^1.9.0",
    "tegaki": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/d3-delaunay": "^6.0.4",
    "@types/opentype.js": "^1.3.10",
    "typescript": "^6.0.3"
  }
}
