{
  "name": "tegaki",
  "version": "0.20.0",
  "type": "module",
  "description": "Framework-agnostic animated handwriting renderer with React, Svelte, Vue, Nuxt, SolidJS, Astro, and Web Components adapters",
  "keywords": [
    "handwriting",
    "animation",
    "svg",
    "react",
    "svelte",
    "vue",
    "solid",
    "astro",
    "nuxt",
    "web-components",
    "custom-elements",
    "font",
    "calligraphy",
    "stroke-order",
    "text-animation",
    "writing-animation"
  ],
  "homepage": "https://github.com/gkurt/tegaki#readme",
  "bugs": {
    "url": "https://github.com/gkurt/tegaki/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gkurt/tegaki.git",
    "directory": "packages/renderer"
  },
  "license": "MIT",
  "bin": {
    "tegaki": "./dist/cli.mjs"
  },
  "author": {
    "name": "Gokhan Kurt",
    "email": "krtgkn@gmail.com",
    "url": "https://gkurt.com"
  },
  "exports": {
    ".": {
      "tegaki@dev": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./core": {
      "tegaki@dev": "./src/core/index.ts",
      "source": "./src/core/index.ts",
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core/index.mjs"
    },
    "./react": {
      "tegaki@dev": "./src/react/index.ts",
      "source": "./src/react/index.ts",
      "types": "./dist/react/index.d.mts",
      "import": "./dist/react/index.mjs"
    },
    "./svelte": {
      "tegaki@dev": "./src/svelte/index.ts",
      "source": "./src/svelte/index.ts",
      "svelte": "./src/svelte/index.ts",
      "default": "./src/svelte/index.ts"
    },
    "./vue": {
      "tegaki@dev": "./src/vue/index.ts",
      "source": "./src/vue/index.ts",
      "default": "./src/vue/index.ts"
    },
    "./nuxt": {
      "tegaki@dev": "./src/nuxt/index.ts",
      "source": "./src/nuxt/index.ts",
      "types": "./src/nuxt/index.ts",
      "default": "./src/nuxt/index.ts"
    },
    "./solid": {
      "tegaki@dev": "./src/solid/index.ts",
      "source": "./src/solid/index.ts",
      "solid": "./src/solid/index.ts",
      "default": "./src/solid/index.ts"
    },
    "./wc": {
      "tegaki@dev": "./src/wc/index.ts",
      "source": "./src/wc/index.ts",
      "types": "./dist/wc/index.d.mts",
      "import": "./dist/wc/index.mjs"
    },
    "./shaper-harfbuzz": {
      "tegaki@dev": "./src/shaper-harfbuzz/index.ts",
      "source": "./src/shaper-harfbuzz/index.ts",
      "types": "./dist/shaper-harfbuzz/index.d.mts",
      "import": "./dist/shaper-harfbuzz/index.mjs"
    },
    "./astro": "./src/astro/TegakiRenderer.astro",
    "./fonts/caveat": {
      "tegaki@dev": "./fonts/caveat/bundle.ts",
      "source": "./fonts/caveat/bundle.ts",
      "types": "./dist/fonts/caveat/bundle.d.mts",
      "node": "./dist/fonts/caveat/bundle.mjs",
      "default": "./dist/fonts/caveat/bundle.mjs"
    },
    "./fonts/italianno": {
      "tegaki@dev": "./fonts/italianno/bundle.ts",
      "source": "./fonts/italianno/bundle.ts",
      "types": "./dist/fonts/italianno/bundle.d.mts",
      "node": "./dist/fonts/italianno/bundle.mjs",
      "default": "./dist/fonts/italianno/bundle.mjs"
    },
    "./fonts/tangerine": {
      "tegaki@dev": "./fonts/tangerine/bundle.ts",
      "source": "./fonts/tangerine/bundle.ts",
      "types": "./dist/fonts/tangerine/bundle.d.mts",
      "node": "./dist/fonts/tangerine/bundle.mjs",
      "default": "./dist/fonts/tangerine/bundle.mjs"
    },
    "./fonts/parisienne": {
      "tegaki@dev": "./fonts/parisienne/bundle.ts",
      "source": "./fonts/parisienne/bundle.ts",
      "types": "./dist/fonts/parisienne/bundle.d.mts",
      "node": "./dist/fonts/parisienne/bundle.mjs",
      "default": "./dist/fonts/parisienne/bundle.mjs"
    },
    "./fonts/suez-one": {
      "tegaki@dev": "./fonts/suez-one/bundle.ts",
      "source": "./fonts/suez-one/bundle.ts",
      "types": "./dist/fonts/suez-one/bundle.d.mts",
      "node": "./dist/fonts/suez-one/bundle.mjs",
      "default": "./dist/fonts/suez-one/bundle.mjs"
    },
    "./fonts/klee-one": {
      "tegaki@dev": "./fonts/klee-one/bundle.ts",
      "source": "./fonts/klee-one/bundle.ts",
      "types": "./dist/fonts/klee-one/bundle.d.mts",
      "node": "./dist/fonts/klee-one/bundle.mjs",
      "default": "./dist/fonts/klee-one/bundle.mjs"
    },
    "./fonts/amiri": {
      "tegaki@dev": "./fonts/amiri/bundle.ts",
      "source": "./fonts/amiri/bundle.ts",
      "types": "./dist/fonts/amiri/bundle.d.mts",
      "node": "./dist/fonts/amiri/bundle.mjs",
      "default": "./dist/fonts/amiri/bundle.mjs"
    },
    "./fonts/tillana": {
      "tegaki@dev": "./fonts/tillana/bundle.ts",
      "source": "./fonts/tillana/bundle.ts",
      "types": "./dist/fonts/tillana/bundle.d.mts",
      "node": "./dist/fonts/tillana/bundle.mjs",
      "default": "./dist/fonts/tillana/bundle.mjs"
    },
    "./fonts/nanum-pen-script": {
      "tegaki@dev": "./fonts/nanum-pen-script/bundle.ts",
      "source": "./fonts/nanum-pen-script/bundle.ts",
      "types": "./dist/fonts/nanum-pen-script/bundle.d.mts",
      "node": "./dist/fonts/nanum-pen-script/bundle.mjs",
      "default": "./dist/fonts/nanum-pen-script/bundle.mjs"
    }
  },
  "files": [
    "dist/",
    "src/",
    "fonts/",
    "README.md",
    "LICENSE",
    "FONTS-LICENSE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun --bun tsdown",
    "prepack": "bun run build && bun ../../scripts/prepareForRelease.ts",
    "generate-fonts": "bun scripts/generate-fonts.ts"
  },
  "dependencies": {},
  "peerDependencies": {
    "harfbuzzjs": "^1.1.0",
    "@nuxt/kit": "^3.0.0 || ^4.0.0",
    "react": ">=18",
    "svelte": ">=5",
    "vue": ">=3",
    "solid-js": ">=1"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "harfbuzzjs": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "harfbuzzjs": "^1.4.0",
    "@nuxt/kit": "^4.4.8",
    "@nuxt/schema": "^4.4.8",
    "@types/react": "^19.2.17",
    "magic-string": "^0.30.21",
    "tegaki-generator": "workspace:*",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
