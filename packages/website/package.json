{
  "name": "@tegaki/website",
  "version": "0.21.0",
  "private": true,
  "type": "module",
  "description": "Documentation and demo website for Tegaki",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gkurt/tegaki.git",
    "directory": "packages/website"
  },
  "imports": {
    "#*": "./*"
  },
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:docker": "./scripts/e2e-docker.sh",
    "test:e2e:docker:update": "./scripts/e2e-docker.sh --update"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.32.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.1",
    "@astrojs/solid-js": "^7.0.1",
    "@astrojs/starlight": "^0.41.3",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@astrojs/svelte": "^9.0.1",
    "@astrojs/vue": "^7.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "fflate": "^0.8.3",
    "gifenc": "^1.0.3",
    "harfbuzzjs": "^1.4.0",
    "opentype.js": "^2.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "solid-js": "^1.9.14",
    "starlight-theme-nova": "^0.12.1",
    "svelte": "^5.56.4",
    "tailwindcss": "^4.3.2",
    "tegaki": "workspace:*",
    "tegaki-generator": "workspace:*",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/opentype.js": "^1.3.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
